      <Label fx:id="QuantityLabel" layoutX="14.0" layoutY="100.0" prefHeight="18.0" prefWidth="230.0" style="-fx-background-color: white;" text="Quantity: " />
      <Label fx:id="ProductionDateLabel" layoutX="14.0" layoutY="128.0" prefHeight="18.0" prefWidth="230.0" style="-fx-background-color: white;" text="Production Date:" />
