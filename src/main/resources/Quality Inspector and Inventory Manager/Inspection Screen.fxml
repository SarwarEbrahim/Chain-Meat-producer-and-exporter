      <Button layoutX="140.0" layoutY="330.0" mnemonicParsing="false" onAction="#ReviewInspectionButtonOnAction" prefHeight="38.0" prefWidth="111.0" text="Review Inspection" />
      <Button layoutX="319.0" layoutY="330.0" mnemonicParsing="false" onAction="#BackButtonOnAction" prefHeight="38.0" prefWidth="44.0" text="Back " />
      <Label layoutX="358.0" layoutY="56.0" prefHeight="18.0" prefWidth="230.0" style="-fx-background-color: yellow;" text="Guidelines:- Temp: 0–5°C- Hygiene: ≥7" />
