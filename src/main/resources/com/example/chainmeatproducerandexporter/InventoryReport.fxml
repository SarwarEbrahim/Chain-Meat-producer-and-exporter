          <TableColumn fx:id="BatchIDTC" prefWidth="130.39999103546143" text="Batch ID" />
          <TableColumn fx:id="MeatTypeTC" prefWidth="115.20001220703125" text="Meat Type " />
            <TableColumn fx:id="QuantityTC" prefWidth="122.39997863769531" text="Quantity" />
            <TableColumn fx:id="StatusTC" prefWidth="91.20001220703125" text="Status" />
            <TableColumn fx:id="DateTC" prefWidth="133.60000000000002" text="Date" />
        </columns>
      </TableView>
      <Button layoutX="202.0" layoutY="349.0" mnemonicParsing="false" onAction="#SaveToFileOnAction" text="SaveToFile" />
      <Button layoutX="325.0" layoutY="349.0" mnemonicParsing="false" onAction="#BackButtonOnAction" text="Back" />
      <Button layoutX="401.0" layoutY="84.0" mnemonicParsing="false" onAction="#GenerateReportButtonOnAction" text="Generate Report" />
   </children>
</AnchorPane>
