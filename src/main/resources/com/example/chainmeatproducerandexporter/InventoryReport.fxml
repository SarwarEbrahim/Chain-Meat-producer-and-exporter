<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.chainmeatproducerandexporter.ArshadAnjum.InventoryReportController">
   <children>
      <Label layoutY="-2.0" prefHeight="31.0" prefWidth="600.0" style="-fx-background-color: yellow;" text="                                Inventory Report  ">
         <font>
            <Font size="24.0" />
         </font>
      </Label>
      <Label layoutX="68.0" layoutY="49.0" text="From Date:" />
      <DatePicker fx:id="FdateDP" layoutX="140.0" layoutY="45.0" />
      <Label layoutX="329.0" layoutY="49.0" text="To Date:" />
      <DatePicker fx:id="TdateDP" layoutX="401.0" layoutY="45.0" />
      <ComboBox fx:id="comboReportType" layoutX="153.0" layoutY="84.0" prefWidth="150.0" />
      <Label layoutX="63.0" layoutY="88.0" text="Report Type:" />
      <TableView fx:id="InventoryReportTV" layoutX="6.0" layoutY="128.0" prefHeight="200.0" prefWidth="593.0" style="-fx-background-color: grey;">
