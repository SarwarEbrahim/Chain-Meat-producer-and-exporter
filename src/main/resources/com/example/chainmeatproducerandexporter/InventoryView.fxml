      </Label>
      <Label layoutX="62.0" layoutY="53.0" prefHeight="18.0" prefWidth="103.0" text="Search Meat Type:" />
      <TextField fx:id="SearchMeatTypeTF" layoutX="188.0" layoutY="50.0" />
      <Button layoutX="413.0" layoutY="50.0" mnemonicParsing="false" onAction="#invSearchButtonOnAction" text=" Search " />
      <TableView fx:id="InventoryStockTV" layoutY="116.0" prefHeight="200.0" prefWidth="600.0" style="-fx-background-color: grey;">
