<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="722.0" prefWidth="1409.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.chainmeatproducerandexporter.commonFiles.loginPageController">

    <children>
        <Label alignment="TOP_CENTER"
               contentDisplay="TOP"
               layoutX="330.0"
               layoutY="25.0"
               prefHeight="39.0"
               prefWidth="755.0"
               text="WELCOME TO CHAIN MEAT PRODUCER AND EXPORTER"
               textAlignment="CENTER"
               textFill="#150e9e">
            <font>
                <Font name="System Bold" size="27.0" />
            </font>
        </Label>

        <Label layoutX="560.0" layoutY="130.0" text="User ID">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <TextField fx:id="userIdTF"
                   layoutX="660.0"
                   layoutY="125.0"
                   prefHeight="30.0"
                   prefWidth="220.0" />

        <Label layoutX="560.0" layoutY="190.0" text="Password">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <PasswordField fx:id="passwordPF"
                       layoutX="660.0"
                       layoutY="185.0"
                       prefHeight="30.0"
                       prefWidth="220.0" />

        <Label layoutX="560.0" layoutY="250.0" text="Role">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <ComboBox fx:id="roleComboBox"
                  layoutX="660.0"
                  layoutY="245.0"
                  prefHeight="30.0"
                  prefWidth="220.0"
                  promptText="Select Role" />

        <Button fx:id="loginButton"
                alignment="CENTER"
                layoutX="725.0"
                layoutY="310.0"
                mnemonicParsing="false"
                onAction="#LoginButtonOnAction"
                prefHeight="35.0"
                prefWidth="90.0"
                text="Login"
                textFill="#7451ff" />

        <Label fx:id="messageLabel"
               layoutX="610.0"
               layoutY="370.0"
               prefHeight="25.0"
               prefWidth="320.0"
               textFill="red">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
    </children>
</AnchorPane>